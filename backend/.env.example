# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/gtk_data
SYNC_DATABASE_URL=postgresql://user:password@localhost:5432/gtk_data

# JWT
SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS (через запятую)
CORS_ORIGINS=http://localhost:3000

# App
APP_PORT=8005
DEBUG=false
